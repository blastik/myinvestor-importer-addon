{
  "id": "myinvestor-importer",
  "name": "MyInvestor Importer",
  "version": "1.0.0",
  "description": "Import MyInvestor (Inversis) exports into Wealthfolio. Merges the cuenta corriente and fondos exports into buy/sell/switch/cash activities on a single account.",
  "author": "blastik",
  "main": "dist/addon.js",
  "sdkVersion": "3.6.1",
  "minWealthfolioVersion": "3.6.0",
  "enabled": true,
  "hostDependencies": {
    "@wealthfolio/addon-sdk": "^3.6.0",
    "@wealthfolio/ui": "^3.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "permissions": [
    {
      "category": "accounts",
      "functions": [{ "name": "getAll", "isDeclared": true, "isDetected": false }],
      "purpose": "List accounts so the user can select their MyInvestor account"
    },
    {
      "category": "activities",
      "functions": [
        { "name": "getAll", "isDeclared": true, "isDetected": false },
        { "name": "checkImport", "isDeclared": true, "isDetected": false },
        { "name": "create", "isDeclared": true, "isDetected": false },
        { "name": "update", "isDeclared": true, "isDetected": false }
      ],
      "purpose": "Validate and import activities parsed from the MyInvestor exports; read existing account activities to avoid double-recording money already imported as a cross-account transfer by another addon"
    },
    {
      "category": "assets",
      "functions": [{ "name": "create", "isDeclared": true, "isDetected": false }],
      "purpose": "Create new asset entries for unrecognised funds during import"
    },
    {
      "category": "secrets",
      "functions": [
        { "name": "get", "isDeclared": true, "isDetected": false },
        { "name": "set", "isDeclared": true, "isDetected": false }
      ],
      "purpose": "Persist addon configuration (account selection, security mappings) across sessions"
    },
    {
      "category": "ui",
      "functions": [
        { "name": "sidebar.addItem", "isDeclared": true, "isDetected": false },
        { "name": "navigation.navigate", "isDeclared": true, "isDetected": false },
        { "name": "router.add", "isDeclared": true, "isDetected": false },
        { "name": "onDisable", "isDeclared": true, "isDetected": false }
      ],
      "purpose": "Add importer navigation item to sidebar and register addon routes"
    },
    {
      "category": "query",
      "functions": [{ "name": "invalidateQueries", "isDeclared": true, "isDetected": false }],
      "purpose": "Refresh host application data after import"
    },
    {
      "category": "portfolio",
      "functions": [{ "name": "update", "isDeclared": true, "isDetected": false }],
      "purpose": "Trigger portfolio recalculation after import"
    },
    {
      "category": "market-data",
      "functions": [{ "name": "searchTicker", "isDeclared": true, "isDetected": false }],
      "purpose": "Search for securities when mapping unrecognised funds"
    }
  ],
  "keywords": ["myinvestor", "inversis", "importer"],
  "license": "MIT"
}
